datasource db {
  provider = "postgresql"
  // I completely removed the directUrl line from here!
}

generator client {
  provider = "prisma-client-js"
}

// --- Enums ---
enum Role {
  FARMER
  ARTIA
  SADAR
  SUPER_ADMIN
}

enum UserStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

// --- Models ---

model User {
  id            Int        @id @default(autoincrement())
  phone         String?    @unique // Primary login identifier
  email         String?    @unique
  cnic          String?    @unique // Required for verification per design
  password      String
  name          String
  role          Role       @default(FARMER)
  status        UserStatus @default(PENDING) // Represents verification state

  // OTP Fields
  resetOtp      String?
  otpExpires    DateTime?
  isOtpVerified Boolean    @default(false)

  // Auth Tokens
  refreshToken  String?    // Hashed refresh token stored in DB

  // Basic Profile Info
  profileImage  String?
  address       String?
  city          String?

  // --- Hierarchy & Auditing (Self-Relations) ---
  createdBy     Int?
  creator       User?      @relation("UserCreatedBy", fields: [createdBy], references: [id])
  createdUsers  User[]     @relation("UserCreatedBy")

  verifiedBy    Int?
  verifier      User?      @relation("UserVerifiedBy", fields: [verifiedBy], references: [id])
  verifiedUsers User[]     @relation("UserVerifiedBy")
  verifiedAt    DateTime?

  // --- Global Relations ---
  mandiId       Int?
  mandi         Mandi?     @relation(fields: [mandiId], references: [id])

  // --- Role-Specific Profile Links ---
  // A User can have one FarmerProfile (1-to-1)
  // A User can have one ArtiaProfile (1-to-1)
  farmerProfile FarmerProfile? @relation("UserFarmerProfile")
  artiaProfile  ArtiaProfile?
  
  // An Artia can have one PersonalLedger (1-to-1)
  personalLedger PersonalLedger? @relation("UserPersonalLedger")
  
  // If this user is an Artia, they can manage many farmers (1-to-many)
  artiaFarmers  FarmerProfile[] @relation("ArtiaToFarmers")

  notifications Notification[]

  // Artia-Farmer Leave History Relations
  farmerLeftHistories  ArtiaFarmerHistory[] @relation("FarmerLeftHistory")
  artiaLeftHistories   ArtiaFarmerHistory[] @relation("ArtiaLeftHistory")

  // Existing standard relations
  posts         Post[]
  prices        Price[]
  comments      Comment[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([phone])
  @@index([email])
}



model Price {
  id              Int      @id @default(autoincrement())
  name_en         String?
  name_ur         String?
  price           Float
  district        String?
  city            String?
  quality         String?
  additional_info String?
  cropId          Int?
  mandiId         Int?
  unit            String?
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Post {
  id        Int      @id @default(autoincrement())
  title_en  String?
  title_ur  String?
  body_en   String?
  body_ur   String?
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  comments  Comment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model FarmerProfile {
  id                 Int       @id @default(autoincrement())
  
  // 1-to-1 relation to the base User model
  userId             Int       @unique
  user               User      @relation("UserFarmerProfile", fields: [userId], references: [id], onDelete: Cascade)

  // The Artia this farmer is attached to (null if independent/unverified)
  artiaId            Int?
  artia              User?     @relation("ArtiaToFarmers", fields: [artiaId], references: [id])

  mandiId            Int?
  mandi              Mandi?    @relation(fields: [mandiId], references: [id])

  landSize           Float?    // Represented as a Float for acres/hectares

  // Privacy & Consent
  showOnArtiaProfile      Boolean   @default(false)
  shareInCount            Boolean   @default(false)
  showOwnDetailsPublicly  Boolean   @default(false)
  consentUpdatedAt        DateTime?

  // --- Future Relations ---
  // primaryCrops    Crop[]?    // Add this implicit many-to-many relation once you build the Crop model
  ledgers            FarmerLedger[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model FarmerLedger {
  id               Int           @id @default(autoincrement())
  name             String        // e.g. "2024 Season Account", "Wheat Ledger"
  season           String?       // e.g. "Rabi 2024", "Kharif 2025"
  cropName         String?       // e.g. "Wheat", "Cotton", "Sugarcane"
  description      String?       // Any extra notes about this ledger
  farmerId         Int
  farmer           FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  createdByArtiaId Int?          // Artia who created this ledger
  transactions     Transaction[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Transaction {
  id           Int          @id @default(autoincrement())
  ledgerId     Int
  ledger       FarmerLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  amount       Float
  type         String       // CREDIT or DEBIT
  description  String?

  // Patti receipt details
  crop         String?
  quantity     Float?
  rate         Float?
  gross        Float?
  commission   Float?
  expenses     Float?
  net          Float?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Crop {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mandi {
  id             Int             @id @default(autoincrement())
  name           String
  city           String
  users          User[]
  farmerProfiles FarmerProfile[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PersonalLedger {
  id           Int                   @id @default(autoincrement())
  name         String                @default("Personal Ledger")
  description  String?
  userId       Int                   @unique
  user         User                  @relation("UserPersonalLedger", fields: [userId], references: [id], onDelete: Cascade)
  transactions PersonalTransaction[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model PersonalTransaction {
  id          Int            @id @default(autoincrement())
  ledgerId    Int
  ledger      PersonalLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  amount      Float
  type        String         // CREDIT or DEBIT
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ConnectionRequest {
  id        Int      @id @default(autoincrement())
  artiaId   Int
  farmerId  Int
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([artiaId, farmerId])
}

model ArtiaProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName           String?
  shopPhone          String?
  address            String?
  commissionRules    String?  // JSON stringified commission rules
  showFarmerCount    Boolean  @default(false)
  showFarmerDetails  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      // Recipient user id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // E.g. "CONSENT_REQUEST", "INFO"
  title_en  String
  title_ur  String
  body_en   String
  body_ur   String
  metadata  String?  // JSON with extra info e.g. { "artiaId": 3 }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ArtiaFarmerHistory {
  id        Int      @id @default(autoincrement())
  farmerId  Int      // farmer User.id
  artiaId   Int      // artia User.id
  leftBy    String   // 'FARMER' | 'ARTIA'
  leftAt    DateTime @default(now())
  farmer    User     @relation("FarmerLeftHistory", fields: [farmerId], references: [id])
  artia     User     @relation("ArtiaLeftHistory",  fields: [artiaId],  references: [id])
  @@index([farmerId])
  @@index([artiaId])
}

