datasource db {
  provider = "postgresql"
  // I completely removed the directUrl line from here!
}

generator client {
  provider = "prisma-client-js"
}

// --- Enums ---
enum Role {
  FARMER
  ARTIA
  SADAR
  SUPER_ADMIN
  PESTICIDE_SHOP_OWNER
}

enum UserStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

// --- Models ---

model User {
  id            Int        @id @default(autoincrement())
  phone         String?    @unique // Primary login identifier
  email         String?    @unique
  cnic          String?    @unique // Required for verification per design
  password      String
  name          String
  role          Role       @default(FARMER)
    status        UserStatus @default(PENDING) // Represents verification state
    statusReason  String?

  // OTP Fields
  resetOtp      String?
  otpExpires    DateTime?
  isOtpVerified Boolean    @default(false)

  // Auth Tokens
  refreshToken  String?    // Hashed refresh token stored in DB

  // Basic Profile Info
  profileImage  String?
  address       String?
  city          String?

  // --- Hierarchy & Auditing (Self-Relations) ---
  createdBy     Int?
  creator       User?      @relation("UserCreatedBy", fields: [createdBy], references: [id])
  createdUsers  User[]     @relation("UserCreatedBy")

  verifiedBy    Int?
  verifier      User?      @relation("UserVerifiedBy", fields: [verifiedBy], references: [id])
  verifiedUsers User[]     @relation("UserVerifiedBy")
  verifiedAt    DateTime?

  // --- Global Relations ---
  mandiId       Int?
  mandi         Mandi?     @relation(fields: [mandiId], references: [id])

  // --- Role-Specific Profile Links ---
  // A User can have one FarmerProfile (1-to-1)
  // A User can have one ArtiaProfile (1-to-1)
  farmerProfile FarmerProfile? @relation("UserFarmerProfile")
  artiaProfile  ArtiaProfile?
  
  // An Artia can have one PersonalLedger (1-to-1)
  personalLedger PersonalLedger? @relation("UserPersonalLedger")
  
  // If this user is an Artia, they can manage many farmers (1-to-many)
  artiaFarmers  FarmerProfile[] @relation("ArtiaToFarmers")

    notifications Notification[]
    productListings ProductListing[]
    pesticideOwnedShops PesticideShop[] @relation("PesticideShopOwner")
    catalogProductsSubmitted PesticideCatalogProduct[] @relation("CatalogSubmittedBy")
    catalogProductsApproved PesticideCatalogProduct[] @relation("CatalogApprovedBy")
    pesticideShopMemberships PesticideShopStaff[]
    pesticideOrders PesticideOrder[] @relation("PesticideOrderCustomer")
    pesticideReviews PesticideShopReview[]
    pesticideArtiaConnections PesticideShopArtiaConnection[] @relation("PesticideConnectionArtia")
    pesticideReceiptsIssued PesticideArtiaReceipt[] @relation("PesticideReceiptIssuer")
    pesticideReceiptsAsArtia PesticideArtiaReceipt[] @relation("PesticideReceiptArtia")
    pesticideReceiptsAsFarmer PesticideArtiaReceipt[] @relation("PesticideReceiptFarmer")

  // Artia-Farmer Leave History Relations
  farmerLeftHistories  ArtiaFarmerHistory[] @relation("FarmerLeftHistory")
  artiaLeftHistories   ArtiaFarmerHistory[] @relation("ArtiaLeftHistory")

  // Join-table connections (farmers linked to this Artia)
  farmerConnections    FarmerArtiaConnection[] @relation("ArtiaToFarmersConnection")
  bypassRequestsAsTarget   JoinBypassRequest[] @relation("BypassTargetArtia")
  bypassRequestsAsApprover JoinBypassRequest[] @relation("BypassApprover")
  createdLedgers       FarmerLedger[]          @relation("CreatedLedgers")

  // Existing standard relations
  posts         Post[]
  prices        Price[]
  comments      Comment[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([phone])
  @@index([email])
}



model Price {
  id              Int      @id @default(autoincrement())
  name_en         String?
  name_ur         String?
  price           Float
  district        String?
  city            String?
  quality         String?
  additional_info String?
  cropId          Int?
  mandiId         Int?
  unit            String?
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProductListing {
  id          Int      @id @default(autoincrement())
  productName String
  quantity    Float
  unit        String
  askingPrice Float
  description String?
  phone       String
  district    String?
  city        String?
  farmerId    Int
  farmer      User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([district, city])
  @@index([productName])
}

model Post {
  id        Int      @id @default(autoincrement())
  title_en  String?
  title_ur  String?
  body_en   String?
  body_ur   String?
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  comments  Comment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model FarmerProfile {
  id                 Int       @id @default(autoincrement())
  
  // 1-to-1 relation to the base User model
  userId             Int       @unique
  user               User      @relation("UserFarmerProfile", fields: [userId], references: [id], onDelete: Cascade)

  // The Artia this farmer is attached to (null if independent/unverified)
  artiaId            Int?
  artia              User?     @relation("ArtiaToFarmers", fields: [artiaId], references: [id])

  mandiId            Int?
  mandi              Mandi?    @relation(fields: [mandiId], references: [id])

  landSize           Float?    // Represented as a Float for acres/hectares

  // Privacy & Consent
  showOnArtiaProfile      Boolean   @default(false)
  shareInCount            Boolean   @default(false)
  showOwnDetailsPublicly  Boolean   @default(false)
  consentUpdatedAt        DateTime?

  // Join-table connections:
  connections        FarmerArtiaConnection[]

  // --- Future Relations ---
  // primaryCrops    Crop[]?    // Add this implicit many-to-many relation once you build the Crop model
  ledgers            FarmerLedger[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model FarmerLedger {
  id               Int           @id @default(autoincrement())
  name             String        // e.g. "2024 Season Account", "Wheat Ledger"
  season           String?       // e.g. "Rabi 2024", "Kharif 2025"
  cropName         String?       // e.g. "Wheat", "Cotton", "Sugarcane"
  description      String?       // Any extra notes about this ledger
  farmerId         Int
  farmer           FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  createdByArtiaId Int?          // Artia who created this ledger
  createdByArtia   User?         @relation("CreatedLedgers", fields: [createdByArtiaId], references: [id])
  transactions     Transaction[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Transaction {
  id           Int          @id @default(autoincrement())
  ledgerId     Int
  ledger       FarmerLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  amount       Float
  type         String       // CREDIT or DEBIT
  description  String?

  // Patti receipt details
  crop         String?
  quantity     Float?
  rate         Float?
  gross        Float?
  commission   Float?
  expenses     Float?
  net          Float?
  imageUrl     String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Crop {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mandi {
  id             Int             @id @default(autoincrement())
  name           String
  city           String
  users          User[]
  farmerProfiles FarmerProfile[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PersonalLedger {
  id           Int                   @id @default(autoincrement())
  name         String                @default("Personal Ledger")
  description  String?
  userId       Int                   @unique
  user         User                  @relation("UserPersonalLedger", fields: [userId], references: [id], onDelete: Cascade)
  transactions PersonalTransaction[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model PersonalTransaction {
  id          Int            @id @default(autoincrement())
  ledgerId    Int
  ledger      PersonalLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  amount      Float
  type        String         // CREDIT or DEBIT
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ConnectionRequest {
  id        Int      @id @default(autoincrement())
  artiaId   Int
  farmerId  Int
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([artiaId, farmerId])
}

model ArtiaProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName           String?
  shopPhone          String?
  secondPhone        String?  // Optional second phone number for Artia
  address            String?
  commissionRules    String?  // JSON stringified commission rules
  showFarmerCount    Boolean  @default(false)
  showFarmerDetails  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      // Recipient user id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // E.g. "CONSENT_REQUEST", "INFO"
  title_en  String
  title_ur  String
  body_en   String
  body_ur   String
  metadata  String?  // JSON with extra info e.g. { "artiaId": 3 }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ArtiaFarmerHistory {
  id        Int      @id @default(autoincrement())
  farmerId  Int      // farmer User.id
  artiaId   Int      // artia User.id
  leftBy    String   // 'FARMER' | 'ARTIA'
  leftAt    DateTime @default(now())
  farmer    User     @relation("FarmerLeftHistory", fields: [farmerId], references: [id])
  artia     User     @relation("ArtiaLeftHistory",  fields: [artiaId],  references: [id])
  @@index([farmerId])
  @@index([artiaId])
}

model FarmerArtiaConnection {
  id        Int           @id @default(autoincrement())
  farmerId  Int
  farmer    FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  artiaId   Int
  artia     User          @relation("ArtiaToFarmersConnection", fields: [artiaId], references: [id], onDelete: Cascade)
    phone     String?       // Connection-specific phone number added by Artia
    status    String        @default("ACTIVE") // ACTIVE | SUSPENDED
    statusReason String?
  createdAt DateTime      @default(now())

  @@unique([farmerId, artiaId])
  @@index([phone])
}

model JoinBypassRequest {
  id             Int      @id @default(autoincrement())
  farmerName     String
  farmerPhone    String
  farmerCnic     String
  targetArtiaId  Int
  targetArtia    User     @relation("BypassTargetArtia", fields: [targetArtiaId], references: [id])
    reason         String?
    decisionReason String?
  targetRole     String   // "SADAR" or "SUPER_ADMIN"
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById   Int?
  approvedBy     User?    @relation("BypassApprover", fields: [approvedById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// --- Isolated Pesticide Marketplace ---
// Every product, order and Artia credit record is scoped to a pesticide shop.
model PesticideShop {
  id                 Int      @id @default(autoincrement())
  ownerId            Int
  owner              User     @relation("PesticideShopOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  slug               String   @unique
  name               String
  businessName       String?
  description        String?
  tagline            String?
  phone              String
  whatsapp           String?
  email              String?
  address            String?
  city               String?
  district           String?
  licenseNumber      String?
  logoUrl            String?  @default("/icon.svg")
  coverUrl           String?
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String[] @default([])
  googleBusinessUrl  String?
  status             String   @default("PENDING") // PENDING | ACTIVE | SUSPENDED | REJECTED
  deliveryFee        Float    @default(0)
  ratingAverage      Float    @default(0)
  reviewCount        Int      @default(0)
  staff              PesticideShopStaff[]
  products           PesticideProduct[]
  offers             PesticideShopOffer[]
  catalogRequests    PesticideCatalogProduct[] @relation("CatalogRequestedForShop")
  orders             PesticideOrder[]
  artiaConnections   PesticideShopArtiaConnection[]
  reviews            PesticideShopReview[]
  artiaReceipts      PesticideArtiaReceipt[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, city, district])
  @@index([ratingAverage])
}

// Canonical product identity. Shops cannot alter these product facts; they only
// attach their own price and stock through PesticideShopOffer.
model PesticideCatalogProduct {
  id            Int      @id @default(autoincrement())
  genericName   String
  brand         String
  displayName   String?
  category      String?
  description   String?
  images        Json?
  standardUnit  String?
  status        String   @default("active") // active | pending_review | rejected
  rejectionReason String?
  requestedShopId Int?
  requestedShop   PesticideShop? @relation("CatalogRequestedForShop", fields: [requestedShopId], references: [id], onDelete: SetNull)
  submittedById Int?
  submittedBy   User?    @relation("CatalogSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  approvedById  Int?
  approvedBy    User?    @relation("CatalogApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  offers        PesticideShopOffer[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([genericName, brand])
  @@index([status, category])
  @@map("catalog_products")
}

model PesticideShopOffer {
  id               Int      @id @default(autoincrement())
  shopId           Int
  shop             PesticideShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  catalogProductId Int
  catalogProduct   PesticideCatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Restrict)
  price            Float
  stockQuantity    Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orderItems       PesticideOrderItem[]

  @@unique([shopId, catalogProductId])
  @@index([catalogProductId, active])
  @@index([shopId, active])
  @@map("shop_offers")
}

model PesticideShopStaff {
  id        Int           @id @default(autoincrement())
  shopId    Int
  shop      PesticideShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String        @default("OWNER") // OWNER | STAFF
  createdAt DateTime      @default(now())

  @@unique([shopId, userId])
  @@index([userId])
}

model PesticideProduct {
  id                Int           @id @default(autoincrement())
  shopId            Int
  shop              PesticideShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  slug              String
  sku               String
  name              String
  brand             String?
  category          String?
  genericName       String?
  activeIngredient  String?
  description       String?
  usageInstructions String?
  safetyInformation String?
  packSize          String
  price             Float
  stockQuantity     Int           @default(0)
  lowStockThreshold Int           @default(0)
  suitableCrops     String[]      @default([])
  targetPests       String[]      @default([])
  imageUrl          String?
  isCreditEligible  Boolean       @default(false)
  isDeliveryEligible Boolean      @default(true)
  isActive          Boolean       @default(true)
  orderItems        PesticideOrderItem[]
  receiptItems      PesticideArtiaReceiptItem[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([shopId, slug])
  @@unique([shopId, sku])
  @@index([name, category])
  @@index([shopId, isActive])
}

model PesticideShopArtiaConnection {
  id                Int           @id @default(autoincrement())
  shopId            Int
  shop              PesticideShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  artiaId           Int
  artia             User          @relation("PesticideConnectionArtia", fields: [artiaId], references: [id], onDelete: Cascade)
  requestedById     Int
  shopAcceptedAt    DateTime?
  artiaAcceptedAt   DateTime?
  status            String        @default("PENDING") // PENDING | APPROVED | REJECTED | SUSPENDED
  reason            String?
  creditLimit       Float?
  settlementTerms   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  @@unique([shopId, artiaId])
  @@index([artiaId, status])
}

model PesticideOrder {
  id              Int           @id @default(autoincrement())
  orderNumber     String        @unique
  shopId          Int
  shop            PesticideShop @relation(fields: [shopId], references: [id], onDelete: Restrict)
  customerId      Int?
  customer        User?         @relation("PesticideOrderCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String
  notes           String?
  status          String        @default("PENDING")
  subtotal        Float
  deliveryFee     Float         @default(0)
  total           Float
  items           PesticideOrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([shopId, status, createdAt])
  @@index([customerId, createdAt])
}

model PesticideOrderItem {
  id          Int              @id @default(autoincrement())
  orderId     Int
  order       PesticideOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int?
  product     PesticideProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  shopOfferId Int?
  shopOffer   PesticideShopOffer? @relation(fields: [shopOfferId], references: [id], onDelete: SetNull)
  productName String
  sku         String?
  quantity    Int
  unitPrice   Float
  lineTotal   Float
}

model PesticideShopReview {
  id        Int           @id @default(autoincrement())
  shopId    Int
  shop      PesticideShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  body      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([shopId, userId])
  @@index([shopId, createdAt])
}

model PesticideArtiaReceipt {
  id             Int           @id @default(autoincrement())
  reference       String        @unique
  shopId         Int
  shop           PesticideShop @relation(fields: [shopId], references: [id], onDelete: Restrict)
  artiaId        Int
  artia          User          @relation("PesticideReceiptArtia", fields: [artiaId], references: [id], onDelete: Restrict)
  farmerId       Int
  farmer         User          @relation("PesticideReceiptFarmer", fields: [farmerId], references: [id], onDelete: Restrict)
  issuedById     Int
  issuedBy       User          @relation("PesticideReceiptIssuer", fields: [issuedById], references: [id], onDelete: Restrict)
  status         String        @default("ISSUED") // ISSUED | CONFIRMED | VOID
  confirmedAt    DateTime?
  items          PesticideArtiaReceiptItem[]
  createdAt      DateTime      @default(now())
}

model PesticideArtiaReceiptItem {
  id          Int                     @id @default(autoincrement())
  receiptId   Int
  receipt     PesticideArtiaReceipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId   Int?
  product     PesticideProduct?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  quantity    Int
  unitPrice   Float
}
